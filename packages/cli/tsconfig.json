{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "../..",
    "paths": {
      "@appprobe/core/*": ["packages/core/src/*"],
      "@appprobe/skills/*": ["packages/skills/src/*"]
    }
  },
  "include": ["src/**/*"]
}
